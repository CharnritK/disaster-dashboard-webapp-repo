# AI recommendation mode
LLM_ENABLED=false
LLM_PROVIDER=openai
LLM_MODEL=gpt-5.4-mini
LLM_REQUEST_TIMEOUT_MS=15000
LLM_WORKFLOW_REQUEST_TIMEOUT_MS=15000
LLM_DASHBOARD_REQUEST_TIMEOUT_MS=45000
LLM_HANDOFF_REQUEST_TIMEOUT_MS=30000
LLM_MAX_COMPLETION_TOKENS=3200
AI_DAILY_QUOTA=20
AI_BETA_ALLOWED_EMAILS=
AI_BETA_ALLOWED_USER_IDS=
AI_BETA_ALLOW_ALL_AUTHENTICATED=false
AI_USAGE_STORE=memory
METADATA_STORE=memory
ADMIN_EMAILS=
ADMIN_USER_IDS=

# Set exactly one of these as a secret in production.
# LLM_API_KEY takes precedence when both are present.
# LLM_API_KEY=
# OPENAI_API_KEY=

# Recommendation route limits
RECOMMEND_REQUEST_MAX_BYTES=200000
RECOMMEND_RATE_LIMIT_MAX_REQUESTS=20
RECOMMEND_RATE_LIMIT_WINDOW_MS=60000
RECOMMEND_MAX_PROFILES=4
RECOMMEND_MAX_COLUMNS_PER_PROFILE=80
RECOMMEND_MAX_SAMPLE_VALUES_PER_COLUMN=5
RECOMMEND_MAX_STRING_LENGTH=240
RECOMMEND_MAX_DASHBOARD_FACTS=14
RECOMMEND_MAX_SUMMARY_ITEMS=8

# Upload limit
MAX_UPLOAD_SIZE_MB=10

# Auth and metadata persistence placeholders.
# Supabase Auth uses only URL + publishable key in browser/client code.
# Keep secret keys server-side. Do not prefix secret values with NEXT_PUBLIC_.
AUTH_SECRET=
APP_BASE_URL=
DATABASE_URL=
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=
SUPABASE_SECRET_KEY=

NEXT_PUBLIC_COPILOT_API_ENABLED=false
